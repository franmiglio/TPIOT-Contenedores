    {
        "id": "d867827082d8c954",
        "type": "function",
        "z": "d547f7af47639184",
        "name": "function 4",
        "func": "if (msg.payload && msg.payload.altura_cm) {\n    let altura_real = msg.payload.altura_cm;\n    let distancia = msg.distancia_cruda;\n    \n    let porcentaje = 100.0 - ((distancia / altura_real) * 100.0);\n\n    if (porcentaje >= -15 && porcentaje < 0) {\n        porcentaje = 0;\n    }\n    else if (porcentaje < -15) {\n        return null; \n    }\n    \n    if (porcentaje > 100) {\n        porcentaje = 100;\n    }\n\n    msg.payload = [\n        {\n            distancia_cm: distancia,\n            porcentaje_llenado: Math.round(porcentaje)\n        },\n        {\n            contenedor_id: msg.id_contenedor\n        }\n    ];\n    \n    return msg;\n} else {\n    node.warn(\"El contenedor \" + msg.id_contenedor + \" no está registrado.\");\n    return null; \n}",
