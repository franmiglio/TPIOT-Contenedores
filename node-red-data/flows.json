    {
        "id": "f9960e8ba418c234",
        "type": "function",
        "z": "72179c21269928a2",
        "name": "function 1",
        "func": "// Verificamos si el backend nos devolvió la altura (si el contenedor existe)\nif (msg.payload && msg.payload.altura_cm) {\n    let altura_real = msg.payload.altura_cm;\n    let distancia = msg.distancia_cruda;\n    \n    // Cálculo del porcentaje\n    let porcentaje = 100.0 - ((distancia / altura_real) * 100.0);\n    \n    // Filtros por si el sensor lee mal\n    if (porcentaje < 0) porcentaje = 0;\n    if (porcentaje > 100) porcentaje = 100;\n\n    // Formateamos para InfluxDB: Array con [ {Fields}, {Tags} ]\n    msg.payload = [\n        {\n            distancia_cm: distancia,\n            porcentaje_llenado: Math.round(porcentaje)\n        },\n        {\n            contenedor_id: msg.contenedor_id\n        }\n    ];\n    \n    return msg;\n} else {\n    // Si el contenedor no está en la base de datos (Postgres), abortamos\n    node.warn(\"El contenedor \" + msg.contenedor_id + \" no está registrado en el sistema.\");\n    return null; \n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
