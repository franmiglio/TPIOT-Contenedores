    {
        "id": "8be3e8d483c8ea10",
        "type": "function",
        "z": "d547f7af47639184",
        "name": "function 3",
        "func": "let idContenedor = msg.id_contenedor;\nmsg.url = `http://backend:3000/api/contenedores/${idContenedor}/altura`;\nmsg.method = \"PUT\";\n\n// Le mandamos la distancia actual como un JSON en el body\nmsg.payload = {\n    altura_cm: msg.distancia_cruda\n};\n\nreturn msg;",
