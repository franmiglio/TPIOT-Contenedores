        "id": "e1d47ba962575527",
        "type": "function",
        "z": "72179c21269928a2",
        "name": "function 2",
        "func": "let partesTopic = msg.topic.split(\"/\");\nlet id_contenedor = partesTopic[partesTopic.length - 1]; \n\n\nmsg.contenedor_id = id_contenedor;\nmsg.distancia_cruda = parseFloat(msg.payload);\n\nmsg.url = \"http://backend:3000/api/contenedores/\" + id_contenedor + \"/altura\";\n\nreturn msg;",
